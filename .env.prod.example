# Production container environment

# Database backend: sqlite or postgres
DATABASE_BACKEND=sqlite

# Required
SESSION_SECRET=replace-with-a-long-random-string
CRYPTO_SECRET=replace-with-another-long-random-string

# Recommended
FRONTEND_BASE_URL=https://your-domain.example.com
NODE_NAME=new-api-prod
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
MEMORY_CACHE_ENABLED=true

# Optional
# DEBUG=false
# REDIS_CONN_STRING=redis://:password@redis-host:6379/0
# SQL_DSN=postgresql://user:password@host:5432/new-api
# POSTGRES_USER=newapi
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=newapi
# TRUSTED_REDIRECT_DOMAINS=your-domain.example.com

# Optional mail override
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_SSL_ENABLED=false
# SMTP_FORCE_AUTH_LOGIN=false
# SMTP_ACCOUNT=mailer@example.com
# SMTP_FROM=mailer@example.com
# SMTP_TOKEN=replace-with-mail-password
