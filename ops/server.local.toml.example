[server]
name = "aheapi-prod"
provider = "aliyun"
instance_id = "i-xxxxxxxxxxxxxxxxx"
instance_name = "your-instance-name"
region = "cn-hangzhou"
zone = "cn-hangzhou-h"
public_ip = "x.x.x.x"
private_ip = "x.x.x.x"
domain = "example.com"
ssh_user = "root"
ssh_key_path = "C:/Users/Administrator/.ssh/aheapi.pem"
app_dir = "/opt/new-api/app"
os = "Alibaba Cloud Linux 3"
spec = "2C2G"
payment_type = "包年包月"
expires_at = "2026-07-02 23:59:59"
notes = "Replace with your real server metadata"
